rules_version = '2';

// ⚠️ ATENÇÃO: regras ABERTAS (sem autenticação), conforme definido.
// Qualquer pessoa com o endereço do site pode LER e ESCREVER os dados.
// Quando quiser proteger, troque por algo como:
//   allow read, write: if request.auth != null;
// e adicione Firebase Auth + uma tela de login no /admin.
service cloud.firestore {
  match /databases/{database}/documents {
    match /folders/{folderId} {
      allow read, write: if true;
    }
    match /projects/{projectId} {
      allow read, write: if true;
    }
  }
}
